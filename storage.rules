rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Default deny to ensure no overlapping wildcards grant unintended access
    match /{allPaths=**} {
      allow read, write: if false;
    }
    
    match /payslips/{userId}/{fileName} {
      allow read: if request.auth.uid == userId || request.auth.token.role in ['hr','admin'];
      allow write: if request.auth.token.role in ['hr','admin'];
    }

    match /resumes/{internId}/{fileName} {
      allow read: if request.auth.token.role in ['hr','admin'];
      allow write: if request.auth.token.role in ['hr','admin'];
    }

    match /avatars/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId &&
                   request.resource.size < 2 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*');
    }

    match /offer-letters/{internId}/{fileName} {
      allow read: if request.auth.token.role in ['hr','admin'] ||
                  (request.auth.token.role == 'intern' && 
                   firestore.get(/databases/(default)/documents/interns/$(internId)).data.email == request.auth.token.email);
      allow write: if request.auth.token.role in ['hr','admin'];
    }

    match /company/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.role == 'admin';
    }
  }
}
